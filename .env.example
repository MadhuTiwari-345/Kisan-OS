# KISAN-OS Environment Configuration
# Copy this to .env and fill in your actual values

# ============ ENVIRONMENT ============
ENVIRONMENT=development
DEBUG=false

# ============ APP CONFIGURATION ============
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,kisan-os.example.com

# ============ DATABASE ============
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=kisan_os
DB_HOST=postgres
DB_PORT=5432

# Full connection string (for advanced setup)
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/kisan_os
# DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/kisan_os

# ============ REDIS CACHE ============
REDIS_PASSWORD=kisan_redis_pass
REDIS_URL=redis://:kisan_redis_pass@redis:6379/0

# ============ BHASHINI - GOVERNMENT VOICE API ============
# Register at https://dhruva.iitm.ac.in/
BHASHINI_API_KEY=your_bhashini_api_key
BHASHINI_USER_ID=your_user_id

# ============ VECTOR DB - RAG (Pinecone) ============
VECTOR_DB_TYPE=milvus  # milvus, pinecone, faiss
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=kisan-os-advisory
PINECONE_ENVIRONMENT=production

# ============ EXTERNAL APIs ============
# Weather Data
WEATHER_API_KEY=your_openweathermap_api_key

# Agmarknet - Government Market Data
AGMARKNET_API_KEY=optional

# ============ ONDC LOGISTICS INTEGRATION ============
ONDC_ENVIRONMENT=sandbox
ONDC_BUYER_APP_ID=your_ondc_app_id
ONDC_BUYER_APP_URL=https://your-domain.com
ONDC_PRIVATE_KEY=your_private_key
ONDC_PUBLIC_KEY=your_public_key

# ============ LOGISTICS PARTNERS ============
# Delhivery
DELHIVERY_API_KEY=your_delhivery_key
DELHIVERY_ACCOUNT_ID=your_account_id

# Shadowfax
SHADOWFAX_API_KEY=your_shadowfax_key
SHADOWFAX_ACCOUNT_ID=your_account_id

# ============ AWS S3 STORAGE ============
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=kisan-os-storage
AWS_REGION=ap-south-1

# ============ EMAIL / SMTP ============
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=support@kisan-os.com

# ============ LOGGING ============
LOG_LEVEL=INFO
LOG_FILE=/logs/kisan-os.log

# ============ MONITORING ============
SENTRY_DSN=https://your-sentry-dsn@sentry.io/123456

# ============ GRAFANA / PGADMIN ============
GRAFANA_PASSWORD=admin
PGADMIN_EMAIL=admin@kisan-os.com
PGADMIN_PASSWORD=admin

# ============ FRONTEND ============
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NODE_ENV=development
