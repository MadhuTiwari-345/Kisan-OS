# KISAN-OS Backend Environment Variables

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:your-db-password@localhost:54321/kisan_os
DATABASE_URL_SYNC=postgresql://postgres:your-db-password@localhost:54321/kisan_os

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
SECRET_KEY=your-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Application Credentials
GOOGLE_APPLICATION_CREDENTIALS=

# Google OAuth
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CLIENT_ID=your-google-client-id

# OpenAI API
OPENAI_API_KEY=your-openai-api-key

# Bhashini API
BHASHINI_API_KEY=your-bhashini-api-key
BHASHINI_STT_URL=https://dhruva-api.bhashini.gov.in/services/asr/v1/recognize
BHASHINI_TTS_URL=https://dhruva-api.bhashini.gov.in/services/tts/v1/convert
BHASHINI_TRANSLATION_URL=https://dhruva-api.bhashini.gov.in/services/translate/v2

# Agmarknet API
AGMARKNET_API_URL=https://agmarknet.gov.in
AGMARKNET_API_KEY=your-agmarknet-api-key

# ONDC API
ONDC_API_URL=https://api.ondc.org
ONDC_CLIENT_ID=your-ondc-client-id
ONDC_CLIENT_SECRET=your-ondc-client-secret

# AI Models
DISEASE_MODEL_PATH=./ai_models/disease_detection.pth
CROP_RECOMMEND_MODEL_PATH=./ai_models/crop_recommendation.pkl
VECTOR_DB_PATH=./ai_models/vector_store

# External Services
WEATHER_API_KEY=your-weather-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://kisan-os.in

